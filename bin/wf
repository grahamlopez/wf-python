#!/usr/bin/env python3
"""wf - structured AI development workflows.

Usage:
    wf init <name> [options]
    wf run <workflow> [options]
    wf brainstorm <workflow> [options]
    wf plan <workflow> [options]
    wf record-brainstorm <workflow> [--cwd DIR]
    wf submit-plan <workflow> [--cwd DIR]
    wf execute <workflow> [options]
    wf execute-task <workflow> <task-id> [options]
    wf review <workflow> [options]
    wf auto-review <workflow> [options]
    wf close <workflow> [options]
    wf status <workflow> [--cwd DIR]
    wf list [--cwd DIR]
    wf history [--json] [--limit N] [--cwd DIR]
    wf render <workflow> [--cwd DIR]
    wf validate <file>
    wf brief <workflow> <task-id> [--cwd DIR]
    wf recover <workflow> [--cwd DIR]
    wf schema [--component NAME]
    wf config [list|get|set] [options]
    wf template list [--cwd DIR]
    wf template show <name> [--cwd DIR]
    wf template render <name> [args...] [--cwd DIR]
    wf completions <shell>
    wf help [topic]
"""

import argparse
import asyncio
import copy
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

# Add repo root to sys.path so wflib, profiles, adapters are importable.
_REPO_ROOT = str(Path(__file__).resolve().parent.parent)
sys.path.insert(0, _REPO_ROOT)


# ---------------------------------------------------------------------------
# Error helpers
# ---------------------------------------------------------------------------

def _error_exit(message):
    """Print JSON error to stdout and exit 1."""
    print(json.dumps({"error": str(message)}))
    sys.exit(1)


# ---------------------------------------------------------------------------
# CLI handler: wf init
# ---------------------------------------------------------------------------

def _cmd_init(args):
    from wflib.config import resolve_config
    from wflib.git import get_current_branch, get_head
    from wflib.record import create_record, save_record, record_path
    from wflib.worktree import commit_or_amend_workflow_files, create_workflow_worktree, setup_worktree

    cwd = os.path.abspath(args.cwd)

    # Validate git repo
    result = subprocess.run(
        ["git", "rev-parse", "--git-dir"],
        cwd=cwd, capture_output=True, text=True,
    )
    if result.returncode != 0:
        _error_exit("Not a git repository")

    try:
        config = resolve_config(cwd, args.set_overrides)
    except Exception as exc:
        _error_exit(f"Config error: {exc}")

    # If --no-worktree flag, override config
    if args.no_worktree:
        from wflib.config import apply_cli_overrides
        config = apply_cli_overrides(config, worktrees=False)

    try:
        branch = get_current_branch(cwd)
        commit = get_head(cwd)
    except Exception as exc:
        _error_exit(f"Git error: {exc}")

    try:
        record = create_record(
            name=args.name,
            cwd=cwd,
            source_branch=branch,
            source_commit=commit,
            config=config,
        )
    except FileExistsError:
        _error_exit(f"Workflow '{args.name}' already exists")
    except Exception as exc:
        _error_exit(str(exc))

    # Commit the record so worktree branches from a state that includes it
    try:
        commit_or_amend_workflow_files(cwd, args.name)
    except Exception as exc:
        _error_exit(f"Failed to commit record: {exc}")

    # Create workflow worktree unless disabled
    worktree = None
    if config.execute.worktrees and not args.no_worktree:
        try:
            wt = create_workflow_worktree(cwd, args.name)
            worktree = wt.path
            record.workflow.worktree = worktree
            save_record(record, cwd)
            commit_or_amend_workflow_files(cwd, args.name)
            setup_worktree(cwd, wt.path)
        except Exception as exc:
            _error_exit(f"Failed to create worktree: {exc}")

    print(json.dumps({
        "workflowId": record.workflow.id,
        "recordFile": record_path(args.name, cwd),
        "worktree": worktree,
    }))


# ---------------------------------------------------------------------------
# CLI handler: wf submit-plan
# ---------------------------------------------------------------------------

def _cmd_submit_plan(args):
    from wflib.record import load_record, save_record, record_plan
    from wflib.types import plan_from_json, Usage, WorkflowStatus, TaskStatus, _dict_to_dataclass
    from wflib.validate import validate_plan, ValidationError
    from wflib.worktree import commit_or_amend_workflow_files

    cwd = os.path.abspath(args.cwd)

    try:
        record = load_record(args.workflow, cwd)
    except FileNotFoundError:
        _error_exit(f"Workflow '{args.workflow}' not found")
    except ValueError as exc:
        _error_exit(str(exc))

    # Read plan from stdin
    try:
        data = json.load(sys.stdin)
    except json.JSONDecodeError as exc:
        _error_exit(f"Invalid JSON on stdin: {exc}")

    try:
        plan = plan_from_json(data)
    except (ValueError, TypeError) as exc:
        _error_exit(f"Invalid plan data: {exc}")

    # Validate
    warnings = []
    try:
        result = validate_plan(plan)
        warnings = result.warnings
    except ValidationError as exc:
        errors = exc.result.errors
        _error_exit(f"Plan validation failed: {'; '.join(errors)}")
    except ValueError as exc:
        _error_exit(f"Plan validation failed: {exc}")

    # Re-submission policy
    status = record.workflow.status
    if status in (WorkflowStatus.REVIEWING, WorkflowStatus.CLOSING, WorkflowStatus.DONE):
        _error_exit(
            f"Plan submission rejected: workflow has moved past implementation "
            f"(status: {status.value}). Start a new workflow with wf init."
        )

    if status == WorkflowStatus.IMPLEMENTING:
        impl = record.implementation
        if impl:
            non_pending = [
                tid for tid, r in impl.tasks.items()
                if r.status not in (TaskStatus.PENDING,)
            ]
            if non_pending:
                warnings.append(
                    f"Replacing plan with {len(non_pending)} completed tasks. "
                    f"Prior results discarded."
                )

    # Parse usage if provided
    usage = Usage()
    if args.usage:
        try:
            usage_data = json.loads(args.usage)
            usage = _dict_to_dataclass(Usage, usage_data)
        except (json.JSONDecodeError, TypeError, ValueError):
            pass  # Best effort

    record_plan(record, plan, usage)
    save_record(record, cwd)

    try:
        commit_or_amend_workflow_files(cwd, args.workflow)
    except Exception:
        pass  # Best effort

    # Print warnings to stderr
    for w in warnings:
        sys.stderr.write(f"Warning: {w}\n")

    print(json.dumps({
        "message": f"Plan submitted with {len(plan.tasks)} tasks",
        "status": record.workflow.status.value,
        "warnings": warnings,
    }))


# ---------------------------------------------------------------------------
# CLI handler: wf record-brainstorm
# ---------------------------------------------------------------------------

def _cmd_record_brainstorm(args):
    from wflib.record import load_record, save_record, record_brainstorm
    from wflib.types import DesignDecision, Usage, _dict_to_dataclass
    from wflib.worktree import commit_or_amend_workflow_files

    cwd = os.path.abspath(args.cwd)

    try:
        record = load_record(args.workflow, cwd)
    except FileNotFoundError:
        _error_exit(f"Workflow '{args.workflow}' not found")
    except ValueError as exc:
        _error_exit(str(exc))

    # Read brainstorm from stdin
    try:
        data = json.load(sys.stdin)
    except json.JSONDecodeError as exc:
        _error_exit(f"Invalid JSON on stdin: {exc}")

    motivation = data.get("motivation", "")
    solution = data.get("solution", "")
    raw_decisions = data.get("designDecisions", [])

    if not motivation:
        _error_exit("Missing required field: motivation")
    if not solution:
        _error_exit("Missing required field: solution")

    design_decisions = []
    for d in raw_decisions:
        design_decisions.append(DesignDecision(
            decision=d.get("decision", ""),
            rationale=d.get("rationale", ""),
        ))

    # Parse usage if provided
    usage = Usage()
    if args.usage:
        try:
            usage_data = json.loads(args.usage)
            usage = _dict_to_dataclass(Usage, usage_data)
        except (json.JSONDecodeError, TypeError, ValueError):
            pass

    record_brainstorm(record, motivation, solution, design_decisions, usage)
    save_record(record, cwd)

    try:
        commit_or_amend_workflow_files(cwd, args.workflow)
    except Exception:
        pass

    print(json.dumps({
        "message": "Brainstorm recorded",
        "status": record.workflow.status.value,
    }))


# ---------------------------------------------------------------------------
# CLI handler: wf status
# ---------------------------------------------------------------------------

def _cmd_status(args):
    from wflib.record import load_record
    from wflib.render import format_status
    from wflib.types import record_to_json

    cwd = os.path.abspath(args.cwd)

    try:
        record = load_record(args.workflow, cwd)
    except FileNotFoundError:
        _error_exit(f"Workflow '{args.workflow}' not found")
    except ValueError as exc:
        _error_exit(str(exc))

    if getattr(args, 'json', False):
        print(json.dumps(record_to_json(record), indent=2))
    else:
        print(format_status(record))


# ---------------------------------------------------------------------------
# CLI handler: wf list
# ---------------------------------------------------------------------------

def _cmd_list(args):
    from wflib.record import list_records
    from wflib.render import format_history_table
    from wflib.types import WorkflowStatus, record_to_json

    cwd = os.path.abspath(args.cwd)
    records = list_records(cwd)

    if not getattr(args, 'all', False):
        records = [
            r for r in records
            if r.workflow.status not in (WorkflowStatus.DONE, WorkflowStatus.FAILED)
        ]

    if getattr(args, 'json', False):
        print(json.dumps([record_to_json(r) for r in records], indent=2))
    else:
        if not records:
            print("No workflows found.")
        else:
            print(format_history_table(records))


# ---------------------------------------------------------------------------
# CLI handler: wf history
# ---------------------------------------------------------------------------

def _cmd_history(args):
    from wflib.record import list_records
    from wflib.render import format_history_table
    from wflib.types import record_to_json

    cwd = os.path.abspath(args.cwd)
    records = list_records(cwd)

    limit = getattr(args, 'limit', 20) or 20

    if getattr(args, 'json', False):
        print(json.dumps([record_to_json(r) for r in records[:limit]], indent=2))
    else:
        if not records:
            print("No workflows found.")
        else:
            print(format_history_table(records, limit=limit))


